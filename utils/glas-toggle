#!/bin/bash
# Toggle the hyprwhspr dictation daemon (systemd user unit) with a
# desktop notification showing the new state. Bound to the "Dictation"
# launcher entry; also fine to run from a terminal or a KDE shortcut.

UNIT=hyprwhspr.service

if systemctl --user is-active --quiet "$UNIT"; then
    systemctl --user stop "$UNIT"
    notify-send -a Glas -i microphone-sensitivity-muted \
        "Glas stopped" "F9 no longer records."
else
    systemctl --user start "$UNIT"
    # READY takes a few seconds (model load); tell the truth about it
    notify-send -a Glas -i audio-input-microphone \
        "Glas starting…" "Hold F9 to talk once the model loads (~5 s)."
fi
