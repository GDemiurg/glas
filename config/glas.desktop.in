[Desktop Entry]
Type=Application
Name=Glas
GenericName=Voice dictation
Comment=Local push-to-talk dictation — settings and control
Exec=@ROOT@/bin/glas-settings
Icon=glas
Terminal=false
Categories=Utility;Accessibility;Settings;
