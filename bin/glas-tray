#!/usr/bin/env python3
"""
Glas tray icon — Ayatana AppIndicator (GTK3), same mechanism Discord/Viber
use, so menus render reliably on every tray host. Runs standalone as its
own small process; the settings GUI spawns it if it isn't running.

Menu: start/stop dictation daemon · LLM cleanup toggle · settings · quit.
"""

import json
import os
import signal
import subprocess
import sys
from pathlib import Path

import gi

gi.require_version('Gtk', '3.0')
gi.require_version('AyatanaAppIndicator3', '0.1')
from gi.repository import GLib, Gtk  # noqa: E402
from gi.repository import AyatanaAppIndicator3 as AppIndicator  # noqa: E402

ROOT = Path(__file__).resolve().parent.parent
CONFIG = Path.home() / '.config/hyprwhspr/config.json'
SERVICE = 'hyprwhspr.service'
LOCK = Path(os.environ.get('XDG_RUNTIME_DIR', '/tmp')) / 'glas-tray.pid'

sys.path.insert(0, str(ROOT / 'lib'))
try:
    from glas_settings import system as _system
except Exception:
    _system = None


def _retint_icon():
    """Match the launcher/tray glyph to the saved theme before the indicator
    loads it by name. No-op if the settings helper can't be imported."""
    if _system is None:
        return
    try:
        theme = json.loads(CONFIG.read_text()).get(
            'app_icon_theme', _system.DEFAULT_ICON_THEME)
    except Exception:
        theme = _system.DEFAULT_ICON_THEME
    _system.render_themed_icon(theme)


def daemon_active() -> bool:
    r = subprocess.run(['systemctl', '--user', 'is-active', SERVICE],
                       capture_output=True, text=True)
    return r.stdout.strip() == 'active'


def cleanup_enabled() -> bool:
    try:
        return bool(json.loads(CONFIG.read_text()).get('llm_cleanup', False))
    except Exception:
        return False


class Tray:
    def __init__(self):
        _retint_icon()
        self.ind = AppIndicator.Indicator.new(
            'glas', 'glas', AppIndicator.IndicatorCategory.APPLICATION_STATUS)
        self.ind.set_status(AppIndicator.IndicatorStatus.ACTIVE)
        self.ind.set_title('Glas')

        self.menu = Gtk.Menu()

        self.item_daemon = Gtk.MenuItem(label='…')
        self.item_daemon.connect('activate', self.on_toggle_daemon)
        self.menu.append(self.item_daemon)

        self.item_cleanup = Gtk.CheckMenuItem(label='LLM cleanup')
        self.cleanup_handler = self.item_cleanup.connect(
            'toggled', self.on_toggle_cleanup)
        self.menu.append(self.item_cleanup)

        self.menu.append(Gtk.SeparatorMenuItem())

        self.item_settings = Gtk.MenuItem(label='Open settings')
        self.item_settings.connect('activate', self.on_settings)
        self.menu.append(self.item_settings)

        self.menu.append(Gtk.SeparatorMenuItem())

        item = Gtk.MenuItem(label='Quit Glas tray')
        item.connect('activate', lambda *_: Gtk.main_quit())
        self.menu.append(item)

        self.menu.show_all()
        self.ind.set_menu(self.menu)
        # Left-click opens the menu on Plasma (SNI reserves Activate); mirror
        # DemiCrm and wire middle-click to the primary "open" action.
        self.ind.set_secondary_activate_target(self.item_settings)

        self.refresh()
        GLib.timeout_add_seconds(3, self.refresh)

    def refresh(self):
        active = daemon_active()
        self.item_daemon.set_label(
            'Stop dictation' if active else 'Start dictation')
        # Block the toggled handler while syncing state from config
        self.item_cleanup.handler_block(self.cleanup_handler)
        self.item_cleanup.set_active(cleanup_enabled())
        self.item_cleanup.handler_unblock(self.cleanup_handler)
        return True

    def on_toggle_daemon(self, _item):
        action = 'stop' if daemon_active() else 'start'
        subprocess.Popen(['systemctl', '--user', action, SERVICE])
        GLib.timeout_add(1200, lambda: (self.refresh(), False)[1])

    def on_toggle_cleanup(self, item):
        try:
            cfg = json.loads(CONFIG.read_text()) if CONFIG.exists() else {}
            cfg['llm_cleanup'] = bool(item.get_active())
            CONFIG.write_text(json.dumps(cfg, indent=2, ensure_ascii=False) + '\n')
            if daemon_active():
                subprocess.Popen(['systemctl', '--user', 'restart', SERVICE])
        except Exception as e:
            print(f'[GLAS-TRAY] cleanup toggle failed: {e}', flush=True)

    def on_settings(self, _item):
        subprocess.Popen([str(ROOT / 'bin' / 'glas-settings')],
                         start_new_session=True)


def main():
    # Single instance
    if LOCK.exists():
        try:
            pid = int(LOCK.read_text())
            if Path(f'/proc/{pid}/comm').exists():
                print('[GLAS-TRAY] already running', flush=True)
                return 0
        except (ValueError, OSError):
            pass
    LOCK.write_text(str(os.getpid()))
    signal.signal(signal.SIGTERM, lambda *_: Gtk.main_quit())
    try:
        Tray()
        Gtk.main()
    finally:
        try:
            LOCK.unlink()
        except OSError:
            pass
    return 0


if __name__ == '__main__':
    sys.exit(main())
